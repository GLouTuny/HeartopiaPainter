# Normalize line endings and treat as text (recommended for cross‑platform repos).
* text=auto

# Explicitly use LF for Python so scripts behave the same on Windows and Unix.
*.py text eol=lf

# Mark binary files so Git doesn't try to merge or show diffs.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.pyc binary
